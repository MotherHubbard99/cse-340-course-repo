<%- include('partials/header') %>

<main>
  <h1>
    <%= title %>
  </h1>
    <p>Upcoming Service Projects</p>
    <ul>
        <% projects.forEach(project => { %>
            <li><strong><%= project.date.toDateString() %></strong>: <%= project.title %> (<%=project.organization_name %>) - <%= project.description %> in <%= project.location %></li>
              
        <% }); %>
    </ul>
  </main>
  
<%- include('partials/footer') %>
